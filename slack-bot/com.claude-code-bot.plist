<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-code-bot</string>
    <key>ProgramArguments</key>
    <array>
        <string>node</string>
        <string>/path/to/your/slack-bot/index.js</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/path/to/your/slack-bot</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/path/to/your/home</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/path/to/your/slack-bot/bot.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/your/slack-bot/bot.err</string>
</dict>
</plist>
